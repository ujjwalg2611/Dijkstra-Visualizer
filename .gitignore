# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies (matches at any depth: frontend/node_modules, backend/node_modules, etc.)
**/node_modules
.pnp
.pnp.js

# testing
**/coverage

# production builds
**/build
**/dist

# compiled binaries (never commit compiled executables)
*.exe
**/backend/main

# misc
.DS_Store
**/.DS_Store
.env
.env.local
.env.*.local

# IDE files
.idea/
.vscode/
*.iml

npm-debug.log*
yarn-debug.log*
yarn-error.log*
